<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>net.chikach.jujutsu-intellij</id>
    <vendor email="kazu.chika.shima@gmail.com">chikach</vendor>

    <description><![CDATA[
        First-class <a href="https://jj-vcs.github.io/jj/">Jujutsu</a> (jj) VCS integration for IntelliJ IDEA and other
        JetBrains IDEs.
        <br/><br/>
        <b>Highlights</b>
        <ul>
          <li><b>Working copy</b> via <code>jj commit</code>, with Local Changes populated from <code>jj status</code> —
            no staging step.</li>
          <li><b>New change</b>, <b>Describe</b>, <b>Abandon</b>, <b>Edit</b>, <b>Squash</b>, and <b>Rebase</b>
            (<code>-r</code> / <code>-s</code>) from the VCS menu and Log context menu.</li>
          <li><b>VCS Log</b> tab with jj-native history; working-copy and conflicted commits are colored to stand out.</li>
          <li><b>File History</b>, <b>Annotate</b>, and <b>Diff</b> driven by jj revisions instead of the backing Git
            store.</li>
          <li><b>Bookmarks</b>: create / delete / move / rename / forget, plus track / untrack of
            <code>&lt;bookmark&gt;@&lt;remote&gt;</code> refs and <code>jj git fetch</code> / <code>jj git push</code>.</li>
          <li><b>Toolbar widget</b> showing the working-copy description with a quick bookmark popup.</li>
          <li><b>Conflict resolution</b> opens the IDE merge tool for files jj reports as conflicted.</li>
        </ul>
        <br/>
        Requires the <code>jj</code> CLI on <code>PATH</code> (or configured under
        <b>Settings | Tools | Jujutsu</b>).
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>

    <resource-bundle>messages.JujutsuBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                parentId="tools"
                instance="net.chikach.jujutsuintellij.config.JujutsuConfigurable"
                id="net.chikach.jujutsu.settings"
                bundle="messages.JujutsuBundle"
                key="settings.title"/>

        <notificationGroup id="Jujutsu"
                           displayType="BALLOON"
                           bundle="messages.JujutsuBundle"
                           key="notification.group.name"/>

        <vcs name="Jujutsu"
             vcsClass="net.chikach.jujutsuintellij.vcs.JujutsuVcs"
             displayName="Jujutsu"
             administrativeAreaName=".jj"/>
        <vcsRootChecker implementation="net.chikach.jujutsuintellij.vcs.JjRootChecker"/>
        <directoryIndexExcludePolicy implementation="net.chikach.jujutsuintellij.vcs.JjDirectoryIndexExcludePolicy"/>
        <treeStructureProvider implementation="net.chikach.jujutsuintellij.ui.JjProjectViewProvider"/>
        <postStartupActivity implementation="net.chikach.jujutsuintellij.vcs.JjGitCoexistence"/>
        <postStartupActivity implementation="net.chikach.jujutsuintellij.repo.JjChangeWatcherStartup"/>

        <vcs.commitMessageProvider implementation="net.chikach.jujutsuintellij.vcs.JjCommitMessageProvider"/>

        <logProvider implementation="net.chikach.jujutsuintellij.ui.log.JjLogProvider"/>
        <!-- order=first so our conflict foreground wins over the platform's MergeCommitsHighlighter,
             which grays out every merge commit and would otherwise mask the conflict color. -->
        <logHighlighterFactory order="first"
                               implementation="net.chikach.jujutsuintellij.ui.log.JjLogStyleHighlighter$Factory"/>
    </extensions>

    <actions resource-bundle="messages.JujutsuBundle">
        <action id="Jujutsu.NewChange"
                class="net.chikach.jujutsuintellij.actions.JjNewChangeAction"/>
        <action id="Jujutsu.Describe"
                class="net.chikach.jujutsuintellij.actions.JjDescribeAction"/>
        <action id="Jujutsu.Abandon"
                class="net.chikach.jujutsuintellij.actions.JjAbandonAction"/>
        <action id="Jujutsu.Fetch"
                class="net.chikach.jujutsuintellij.actions.JjFetchAction"/>
        <action id="Jujutsu.Push"
                class="net.chikach.jujutsuintellij.actions.JjPushAction"/>
        <action id="Jujutsu.BookmarkCreate"
                class="net.chikach.jujutsuintellij.actions.JjBookmarkCreateAction"/>
        <action id="Jujutsu.BookmarkDelete"
                class="net.chikach.jujutsuintellij.actions.JjBookmarkDeleteAction"/>
        <action id="Jujutsu.ResolveConflicts"
                class="net.chikach.jujutsuintellij.actions.JjResolveConflictsAction"/>
        <action id="Jujutsu.Edit"
                class="net.chikach.jujutsuintellij.actions.JjEditAction"/>
        <action id="Jujutsu.Log.New"
                class="net.chikach.jujutsuintellij.actions.JjLogNewAction"/>
        <action id="Jujutsu.Log.BookmarkCreate"
                class="net.chikach.jujutsuintellij.actions.JjLogBookmarkCreateAction"/>
        <action id="Jujutsu.Log.BookmarkMove"
                class="net.chikach.jujutsuintellij.actions.JjLogBookmarkMoveAction"/>
        <group id="Jujutsu.Log.BookmarkMenu"
               class="net.chikach.jujutsuintellij.actions.JjLogBookmarkMenuActionGroup"/>
        <action id="Jujutsu.Log.TagCreate"
                class="net.chikach.jujutsuintellij.actions.JjLogTagCreateAction"/>
        <group id="Jujutsu.Log.TagDelete"
               class="net.chikach.jujutsuintellij.actions.JjLogTagDeleteActionGroup"/>
        <action id="Jujutsu.Log.Describe"
                class="net.chikach.jujutsuintellij.actions.JjLogDescribeAction"/>
        <action id="Jujutsu.Log.Abandon"
                class="net.chikach.jujutsuintellij.actions.JjLogAbandonAction"/>
        <action id="Jujutsu.Squash"
                class="net.chikach.jujutsuintellij.actions.JjSquashAction"/>
        <action id="Jujutsu.RebaseRevision"
                class="net.chikach.jujutsuintellij.actions.JjRebaseRevisionAction"/>
        <action id="Jujutsu.RebaseDescendants"
                class="net.chikach.jujutsuintellij.actions.JjRebaseDescendantsAction"/>

        <action id="Jujutsu.RevisionWidget"
                class="net.chikach.jujutsuintellij.ui.JjRevisionWidget">
            <add-to-group group-id="MainToolbarLeft" anchor="last"/>
        </action>

        <group id="Jujutsu.Menu"
               class="net.chikach.jujutsuintellij.actions.JujutsuMenu"
               popup="true"
               searchable="false">
            <reference ref="Jujutsu.NewChange"/>
            <reference ref="Jujutsu.Describe"/>
            <reference ref="Jujutsu.Abandon"/>
            <reference ref="Jujutsu.ResolveConflicts"/>
            <separator/>
            <reference ref="Jujutsu.Fetch"/>
            <reference ref="Jujutsu.Push"/>
            <separator/>
            <group id="Jujutsu.Bookmarks" popup="true">
                <reference ref="Jujutsu.BookmarkCreate"/>
                <reference ref="Jujutsu.BookmarkDelete"/>
            </group>
            <separator/>
            <reference ref="Vcs.ShowTabbedFileHistory"/>
            <reference ref="Annotate"/>
            <reference ref="Compare.SameVersion"/>
            <add-to-group group-id="VcsGlobalGroup" anchor="after" relative-to-action="Vcs.Specific"/>
        </group>

        <group id="Jujutsu.ContextMenu"
               class="net.chikach.jujutsuintellij.actions.JujutsuMenu"
               popup="true"
               searchable="false">
            <reference ref="Jujutsu.NewChange"/>
            <reference ref="Jujutsu.Describe"/>
            <reference ref="Jujutsu.Abandon"/>
            <reference ref="Jujutsu.ResolveConflicts"/>
            <separator/>
            <reference ref="Jujutsu.Fetch"/>
            <reference ref="Jujutsu.Push"/>
            <separator/>
            <reference ref="Vcs.ShowTabbedFileHistory"/>
            <reference ref="Annotate"/>
            <reference ref="Compare.SameVersion"/>
            <reference ref="ChangesView.Revert"/>
            <reference ref="ChangesView.RevertFiles"/>
            <add-to-group group-id="VcsGroup" anchor="last"/>
        </group>

        <group id="Jujutsu.LogContextMenu">
            <reference ref="Jujutsu.Edit"/>
            <reference ref="Jujutsu.Log.New"/>
            <reference ref="Jujutsu.ResolveConflicts"/>
            <separator/>
            <reference ref="Jujutsu.Log.Describe"/>
            <reference ref="Jujutsu.Log.Abandon"/>
            <separator/>
            <reference ref="Jujutsu.Squash"/>
            <reference ref="Jujutsu.RebaseRevision"/>
            <reference ref="Jujutsu.RebaseDescendants"/>
            <separator/>
            <reference ref="Jujutsu.Log.BookmarkCreate"/>
            <reference ref="Jujutsu.Log.BookmarkMove"/>
            <reference ref="Jujutsu.Log.BookmarkMenu"/>
            <separator/>
            <reference ref="Jujutsu.Log.TagCreate"/>
            <reference ref="Jujutsu.Log.TagDelete"/>
            <add-to-group group-id="Vcs.Log.ContextMenu" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
